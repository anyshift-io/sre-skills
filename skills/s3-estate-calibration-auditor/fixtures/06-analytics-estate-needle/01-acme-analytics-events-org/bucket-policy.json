{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "OrgRead",
      "Effect": "Allow",
      "Principal": "*",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::acme-analytics-events-org",
        "arn:aws:s3:::acme-analytics-events-org/*"
      ],
      "Condition": {
        "StringEquals": {
          "aws:PrincipalOrgID": "o-7x3k9m2qab"
        }
      }
    }
  ]
}