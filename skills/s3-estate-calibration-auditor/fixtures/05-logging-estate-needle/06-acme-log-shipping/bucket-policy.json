{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PartnerLogIngest",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::905638217741:root"
      },
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::acme-log-shipping",
        "arn:aws:s3:::acme-log-shipping/*"
      ]
    }
  ]
}