{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PartnerExtId",
      "Effect": "Allow",
      "Principal": "*",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": [
        "arn:aws:s3:::acme-tenant-partner-feed",
        "arn:aws:s3:::acme-tenant-partner-feed/*"
      ],
      "Condition": {
        "StringEquals": {
          "sts:ExternalId": "acme-partner-7731"
        }
      }
    }
  ]
}