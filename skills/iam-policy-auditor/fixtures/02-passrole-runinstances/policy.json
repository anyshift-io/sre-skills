{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ManageBuildFleet",
      "Effect": "Allow",
      "Action": [
        "ec2:RunInstances",
        "ec2:DescribeInstances",
        "ec2:DescribeImages"
      ],
      "Resource": "*"
    },
    {
      "Sid": "PassInstanceProfileRoles",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "*"
    }
  ]
}
