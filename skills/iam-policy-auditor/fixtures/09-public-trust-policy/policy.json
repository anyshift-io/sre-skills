{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadIngestBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::partner-ingest-zone",
        "arn:aws:s3:::partner-ingest-zone/*"
      ]
    }
  ]
}
