{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadBillingArtifacts",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::cost-reports-export",
        "arn:aws:s3:::cost-reports-export/*"
      ]
    },
    {
      "Sid": "ReadBudgets",
      "Effect": "Allow",
      "Action": [
        "budgets:ViewBudget",
        "budgets:DescribeBudgetActionsForBudget"
      ],
      "Resource": "*"
    }
  ]
}
